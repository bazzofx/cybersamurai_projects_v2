rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Projects Collection: Anyone can read, only authenticated admin can write
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users Collection: Anyone can read to check authorization roles, authenticated users can write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
